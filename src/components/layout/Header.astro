---
import { getCollection } from 'astro:content';
import { readData } from '../../lib/readData';

const siteConfig = readData('siteConfig.json');
const categoriesData = readData('categories.json', []);
const menuItems: any[] = readData('menu.json', { items: [] }).items || [];

const posts = await getCollection('blog');
const categoriesFromPosts = [...new Set(posts.map(post => post.data.category).filter(Boolean))];

const finalCategoriesData = Array.isArray(categoriesData) ? categoriesData : [];
const allCategories = finalCategoriesData.length > 0 ? finalCategoriesData : categoriesFromPosts;

// menuHoverEnabled controla se o submenu abre passando o mouse (true) ou só ao clicar (false)
const menuHoverEnabled = siteConfig?.menuHoverEnabled !== false;
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-sm" data-menu-hover={menuHoverEnabled ? 'on' : 'off'}>
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 flex-shrink-0">
        {siteConfig.logo ? (
          <img src={siteConfig.logo} alt={siteConfig.name} class="w-auto object-contain" style={`height: ${siteConfig.logoHeight || 32}px; max-height: ${siteConfig.logoHeight || 32}px`} />
        ) : (
          <span class="text-xl font-bold text-primary-500">{siteConfig.name}</span>
        )}
      </a>

      <!-- Nav desktop -->
      <nav class="hidden md:flex items-center gap-1">
        {menuItems.map((item: any) => (
          item.showCategories ? (
            <div class="relative group cms-dropdown">
              <a href={item.href} class="cms-dropdown-trigger px-4 py-2 text-sm font-medium text-slate-600 hover:text-primary-500 transition-colors rounded-lg hover:bg-gray-50 flex items-center gap-1 cursor-pointer" data-cms-dropdown-trigger>
                {item.label}
                <svg class="cms-dropdown-chevron w-3 h-3 text-slate-400 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </a>
              <div class="cms-dropdown-panel absolute top-full left-0 pt-2 w-48 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                <div class="bg-white rounded-xl shadow-lg border border-gray-200 py-1 overflow-hidden">
                  <a href={item.href} class="block px-4 py-2.5 text-sm text-slate-700 font-semibold hover:bg-gray-50 hover:text-primary-500 transition-colors border-b border-gray-100">
                    Todos os Artigos
                  </a>
                  {allCategories.map((cat) => (
                    <a
                      href={`/categoria/${cat.toLowerCase().replace(/[^a-z0-9]/g, '-')}`}
                      class="block px-4 py-2 text-sm text-slate-600 hover:bg-gray-50 hover:text-primary-500 transition-colors"
                    >
                      {cat}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a href={item.href} class="px-4 py-2 text-sm font-medium text-slate-600 hover:text-primary-500 transition-colors rounded-lg hover:bg-gray-50">
              {item.label}
            </a>
          )
        ))}
      </nav>

      <!-- Ações direita -->
      <div class="flex items-center gap-3">
        <!-- Redes sociais desktop -->
        <div class="hidden lg:flex items-center gap-2">
          {siteConfig.social?.instagram && (
            <a href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer"
               class="w-8 h-8 rounded-full bg-gray-100 hover:bg-primary-500 text-slate-500 hover:text-white flex items-center justify-center transition-all">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
          )}
          {siteConfig.social?.twitter && (
            <a href={siteConfig.social.twitter} target="_blank" rel="noopener noreferrer"
               class="w-8 h-8 rounded-full bg-gray-100 hover:bg-primary-500 text-slate-500 hover:text-white flex items-center justify-center transition-all">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
          )}
          {siteConfig.social?.facebook && (
            <a href={siteConfig.social.facebook} target="_blank" rel="noopener noreferrer"
               class="w-8 h-8 rounded-full bg-gray-100 hover:bg-primary-500 text-slate-500 hover:text-white flex items-center justify-center transition-all">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
          )}
          {siteConfig.social?.pinterest && (
            <a href={siteConfig.social.pinterest} target="_blank" rel="noopener noreferrer"
               class="w-8 h-8 rounded-full bg-gray-100 hover:bg-primary-500 text-slate-500 hover:text-white flex items-center justify-center transition-all">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.402.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.357-.629-2.732-1.378l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.367 18.592.001 12.017.001z"/>
              </svg>
            </a>
          )}
        </div>

        <!-- Busca -->
        <button
          id="search-toggle"
          class="w-9 h-9 rounded-full bg-gray-100 hover:bg-primary-500 text-slate-500 hover:text-white flex items-center justify-center transition-all"
          aria-label="Buscar"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>

        <!-- Burger mobile -->
        <button
          id="mobile-menu-toggle"
          class="md:hidden w-9 h-9 rounded-full bg-gray-100 text-slate-600 flex items-center justify-center"
          aria-label="Menu"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-gray-200 bg-white">
    <nav class="max-w-7xl mx-auto px-4 py-3 space-y-1">
      {menuItems.map((item: any) => (
        <>
          <a href={item.href} class="block px-3 py-2 text-sm font-medium text-slate-700 hover:text-primary-500 hover:bg-gray-50 rounded-lg transition-colors">
            {item.label}
          </a>
          {item.showCategories && allCategories.map((cat) => (
            <a
              href={`/categoria/${cat.toLowerCase().replace(/[^a-z0-9]/g, '-')}`}
              class="block px-3 py-2 pl-6 text-sm text-slate-500 hover:text-primary-500 hover:bg-gray-50 rounded-lg transition-colors"
            >
              {cat}
            </a>
          ))}
        </>
      ))}
    </nav>
  </div>
</header>

<!-- Search popup -->
<div id="search-popup" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[200] hidden items-center justify-center p-4">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="font-bold text-slate-800 text-lg">Buscar Artigos</h3>
      <button id="search-close" class="w-8 h-8 rounded-full bg-gray-100 hover:bg-gray-200 text-slate-500 flex items-center justify-center transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div class="relative">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <input
        type="text"
        placeholder="Buscar artigos..."
        class="w-full pl-10 pr-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:border-primary-500 text-slate-800 text-sm"
        autofocus
      />
    </div>
    <p class="text-xs text-slate-400 mt-3">Pressione <kbd class="px-1.5 py-0.5 bg-gray-100 rounded text-slate-500 font-mono">Esc</kbd> para fechar</p>
  </div>
</div>

<script>
  // Mobile menu toggle
  const mobileToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  mobileToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  // Search popup
  const searchToggle = document.getElementById('search-toggle');
  const searchPopup = document.getElementById('search-popup');
  const searchClose = document.getElementById('search-close');

  searchToggle?.addEventListener('click', () => {
    searchPopup?.classList.remove('hidden');
    searchPopup?.classList.add('flex');
    searchPopup?.querySelector('input')?.focus();
  });

  const closeSearch = () => {
    searchPopup?.classList.add('hidden');
    searchPopup?.classList.remove('flex');
  };

  searchClose?.addEventListener('click', closeSearch);
  searchPopup?.addEventListener('click', (e) => {
    if (e.target === searchPopup) closeSearch();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSearch();
  });

  // CMS dropdown — click toggle (acessibilidade + modo click-only)
  document.querySelectorAll('[data-cms-dropdown-trigger]').forEach(trigger => {
    trigger.addEventListener('click', (e) => {
      const drop = trigger.closest('.cms-dropdown') as HTMLElement | null;
      if (!drop) return;
      e.preventDefault();
      const wasOpen = drop.classList.contains('is-open');
      document.querySelectorAll('.cms-dropdown.is-open').forEach(d => d.classList.remove('is-open'));
      if (!wasOpen) drop.classList.add('is-open');
    });
  });
  document.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    if (!t.closest('.cms-dropdown')) {
      document.querySelectorAll('.cms-dropdown.is-open').forEach(d => d.classList.remove('is-open'));
    }
  });
</script>

<style>
  /* Modo click-only: neutraliza o hover do Tailwind, mostra apenas via .is-open */
  header[data-menu-hover="off"] .cms-dropdown:hover > .cms-dropdown-panel {
    opacity: 0 !important;
    visibility: hidden !important;
  }
  header[data-menu-hover="off"] .cms-dropdown:hover .cms-dropdown-chevron {
    transform: none !important;
  }
  /* Estado aberto via click sempre visível, em qualquer modo */
  .cms-dropdown.is-open > .cms-dropdown-panel {
    opacity: 1 !important;
    visibility: visible !important;
  }
  .cms-dropdown.is-open .cms-dropdown-chevron {
    transform: rotate(180deg);
  }
</style>
