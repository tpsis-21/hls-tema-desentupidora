---
import { readData } from '../../lib/readData';

const pluginsConfig = readData('pluginsConfig.json', {}) as any;
const cc = pluginsConfig?.cookieConsent;
const enabled = cc?.enabled !== false;
const headline = cc?.headline || 'Privacidade e Cookies';
const description = cc?.description || 'Utilizamos cookies para melhorar sua experiência. Ao clicar em "Aceitar", você concorda com nossa política de privacidade.';
const buttonAccept = cc?.buttonAccept || 'Aceitar';
const buttonReject = cc?.buttonReject || 'Ler Política';
const rejectUrl = cc?.rejectUrl || '/privacidade';
const position = cc?.position || 'bottom';

const posClass = position === 'top'
  ? 'fixed top-4 left-4 right-4 md:left-auto md:right-6 md:max-w-sm'
  : 'fixed bottom-6 left-4 right-4 md:left-auto md:right-6 md:max-w-sm';
const slideClass = position === 'top' ? '-translate-y-20' : 'translate-y-20';
---

{enabled && (
  <div
    id="cookie-banner"
    class={`${posClass} z-[100] transform ${slideClass} opacity-0 transition-all duration-500 pointer-events-none`}
    style={`position:fixed;${position === 'top' ? 'top:1rem;' : 'bottom:1.5rem;'}right:1.5rem;left:auto;max-width:400px;z-index:100;transition:opacity .5s, transform .5s;`}
    data-accept-text={buttonAccept}
  >
    <div style="background:#fff;color:#1e293b;padding:1.25rem;border-radius:1rem;box-shadow:0 25px 50px -12px rgba(0,0,0,.25);border:1px solid #e5e7eb;">
      <div style="display:flex;align-items:flex-start;gap:0.75rem;margin-bottom:1rem;">
        <div style={`width:40px;height:40px;min-width:40px;border-radius:0.75rem;display:flex;align-items:center;justify-content:center;background:var(--walker-primary,#FE4F70);`}>
          <svg xmlns="http://www.w3.org/2000/svg" style="width:20px;height:20px;color:#fff;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
        <div>
          <h4 style="font-weight:700;font-size:0.875rem;margin:0 0 4px 0;color:#1e293b;">{headline}</h4>
          <p style="color:#64748b;font-size:0.75rem;line-height:1.5;margin:0;">{description}</p>
        </div>
      </div>
      <div style="display:flex;gap:0.75rem;">
        <button
          id="accept-cookies"
          style={`flex:1;padding:0.625rem 1rem;border-radius:0.75rem;color:#fff;font-weight:700;font-size:0.875rem;border:none;cursor:pointer;background:var(--walker-primary,#FE4F70);`}
        >
          {buttonAccept}
        </button>
        <a
          href={rejectUrl}
          style="flex:1;padding:0.625rem 1rem;border-radius:0.75rem;background:#f1f5f9;color:#334155;font-weight:700;font-size:0.875rem;text-align:center;text-decoration:none;"
        >
          {buttonReject}
        </a>
      </div>
    </div>
  </div>
)}

<script>
(function() {
  var banner = document.getElementById('cookie-banner');
  var acceptBtn = document.getElementById('accept-cookies');

  if (!banner || !acceptBtn) return;

  var slideClass = banner.classList.contains('-translate-y-20') ? '-translate-y-20' : 'translate-y-20';
  // Set inline styles primary (mais robusto que classes Tailwind — funciona mesmo se purge agressivo apagar opacity-0/pointer-events-none).
  function showBanner() {
    banner.classList.remove(slideClass, 'opacity-0', 'pointer-events-none');
    banner.style.opacity = '1';
    banner.style.pointerEvents = 'auto';
    banner.style.transform = 'translateY(0)';
  }
  function hideBanner() {
    banner.classList.add(slideClass, 'opacity-0', 'pointer-events-none');
    banner.style.opacity = '0';
    banner.style.pointerEvents = 'none';
    banner.style.transform = slideClass === '-translate-y-20' ? 'translateY(-5rem)' : 'translateY(5rem)';
  }
  // Estado inicial: escondido até decidir
  hideBanner();

  // Show if not yet accepted
  if (!localStorage.getItem('cookies-accepted')) {
    setTimeout(showBanner, 1500);
  }

  acceptBtn.addEventListener('click', function() {
    localStorage.setItem('cookies-accepted', 'true');
    hideBanner();
    // Emit event for GA/Pixel deferred loading
    window.dispatchEvent(new CustomEvent('cookies-accepted'));
  });
})();
</script>
