---
export const prerender = false;
import { validateSession, COOKIE_NAME_EXPORT } from '../../lib/auth';
const cookie = Astro.cookies.get(COOKIE_NAME_EXPORT)?.value;
if (cookie && (await validateSession(cookie))) return Astro.redirect('/admin');
const noSecret = !import.meta.env.ADMIN_SECRET;
---
<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Entrar — Painel</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #ffffff;
      --fg: #0a0a0a;
      --muted: #737373;
      --primary: #ea580c;
      --primary-hover: #c2410c;
      --border: #e5e5e5;
      --accent: #fff7ed;
    }
    * { box-sizing: border-box; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      margin: 0;
      min-height: 100vh;
      display: grid;
      place-items: center;
      background: var(--bg);
      color: var(--fg);
      -webkit-font-smoothing: antialiased;
    }
    .card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 2rem;
      width: min(92vw, 380px);
      box-shadow: 0 1px 2px rgba(0,0,0,.05);
    }
    .brand {
      display: flex;
      align-items: center;
      gap: 0.625rem;
      margin-bottom: 1.5rem;
    }
    .brand-icon {
      width: 2rem;
      height: 2rem;
      border-radius: 0.5rem;
      background: var(--primary);
      display: grid;
      place-items: center;
      color: #fff;
      font-weight: 700;
      font-size: 0.875rem;
    }
    h1 { font-size: 1.125rem; font-weight: 700; margin: 0; letter-spacing: -0.02em; }
    .sub { font-size: 0.875rem; color: var(--muted); margin: 0.25rem 0 0; }
    label { font-size: 0.875rem; font-weight: 600; display: block; margin-bottom: 0.35rem; }
    input {
      width: 100%;
      padding: 0.7rem 0.875rem;
      border: 1px solid var(--border);
      border-radius: 10px;
      font: inherit;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    input:focus {
      outline: none;
      border-color: var(--primary);
      box-shadow: 0 0 0 3px color-mix(in oklab, var(--primary) 25%, transparent);
    }
    button {
      width: 100%;
      margin-top: 1rem;
      padding: 0.7rem;
      border: 0;
      border-radius: 10px;
      background: var(--primary);
      color: #fff;
      font-weight: 600;
      font-size: 0.875rem;
      cursor: pointer;
      transition: background 0.15s;
    }
    button:hover { background: var(--primary-hover); }
    .err { color: #dc2626; font-size: 0.85rem; margin-top: 0.75rem; min-height: 1.2em; }
    .warn {
      background: var(--accent);
      border: 1px solid color-mix(in oklab, var(--primary) 35%, var(--border));
      border-radius: 10px;
      padding: 0.75rem;
      font-size: 0.85rem;
      color: #9a3412;
    }
  </style>
</head>
<body>
  <form class="card" id="f">
    <div class="brand">
      <div class="brand-icon" aria-hidden="true">M</div>
      <div>
        <h1>Painel da clínica</h1>
        <p class="sub">Entre com sua senha de administrador</p>
      </div>
    </div>
    {noSecret ? (
      <p class="warn">Configure <code>ADMIN_SECRET</code> no ambiente para ativar o login.</p>
    ) : (
      <>
        <label for="pw">Senha</label>
        <input id="pw" name="password" type="password" autocomplete="current-password" required />
        <button type="submit">Entrar</button>
        <p class="err" id="e"></p>
      </>
    )}
  </form>
  <script>
    const f = document.getElementById('f');
    f?.addEventListener('submit', async (ev) => {
      ev.preventDefault();
      const e = document.getElementById('e');
      const password = (document.getElementById('pw')).value;
      const r = await fetch('/api/admin/login', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ password }) });
      if (r.ok) { location.href = '/admin'; } else { const j = await r.json().catch(()=>({})); e.textContent = j.error || 'Senha incorreta.'; }
    });
  </script>
</body>
</html>
