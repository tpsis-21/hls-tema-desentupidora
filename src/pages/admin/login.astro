---
export const prerender = false;
import { validateSession } from '../../lib/auth';
import '../../styles/admin.css';

const cookieHeader = Astro.request.headers.get('cookie') || '';
const cookies = Object.fromEntries(
    cookieHeader.split(';').map(c => {
        const [k, ...v] = c.trim().split('=');
        return [k, decodeURIComponent(v.join('='))];
    })
);
const valid = await validateSession(cookies['admin_session']);
if (valid) return Astro.redirect('/admin');
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Entrar — Painel</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root { --bg:#fff; --fg:#0a0a0a; --muted:#737373; --primary:#ea580c; --primary-hover:#c2410c; --border:#e5e5e5; --accent:#fff7ed; }
        * { box-sizing: border-box; }
        body { font-family:'Inter',system-ui,sans-serif; margin:0; min-height:100vh; display:grid; place-items:center; background:var(--bg); color:var(--fg); }
        .card { background:#fff; border:1px solid var(--border); border-radius:16px; padding:2rem; width:min(92vw,380px); box-shadow:0 1px 2px rgba(0,0,0,.05); }
        .brand { display:flex; align-items:center; gap:.625rem; margin-bottom:1.5rem; }
        .brand-icon { width:2rem; height:2rem; border-radius:.5rem; background:var(--primary); display:grid; place-items:center; color:#fff; font-weight:700; }
        h1 { font-size:1.125rem; font-weight:700; margin:0; }
        .sub { font-size:.875rem; color:var(--muted); margin:.25rem 0 0; }
        label { font-size:.875rem; font-weight:600; display:block; margin-bottom:.35rem; }
        input { width:100%; padding:.7rem .875rem; border:1px solid var(--border); border-radius:10px; font:inherit; }
        input:focus { outline:none; border-color:var(--primary); box-shadow:0 0 0 3px color-mix(in oklab,var(--primary) 25%,transparent); }
        button { width:100%; margin-top:1rem; padding:.7rem; border:0; border-radius:10px; background:var(--primary); color:#fff; font-weight:600; cursor:pointer; }
        button:hover { background:var(--primary-hover); }
        button:disabled { opacity:.6; cursor:not-allowed; }
        .err { color:#dc2626; font-size:.85rem; margin-top:.75rem; min-height:1.2em; }
    </style>
</head>
<body>
    <form class="card" id="f">
        <div class="brand">
            <div class="brand-icon" aria-hidden="true">M</div>
            <div>
                <h1>Painel do blog</h1>
                <p class="sub">Entre com sua senha de administrador</p>
            </div>
        </div>
        <label for="password">Senha</label>
        <input id="password" type="password" autocomplete="current-password" required autofocus />
        <button type="submit" id="loginBtn">Entrar</button>
        <p class="err" id="error"></p>
    </form>
    <script>
        const f = document.getElementById('f');
        const btn = document.getElementById('loginBtn');
        const input = document.getElementById('password');
        const errorEl = document.getElementById('error');
        f?.addEventListener('submit', async (ev) => {
            ev.preventDefault();
            const password = input.value;
            if (!password) return;
            btn.disabled = true;
            btn.textContent = 'Verificando...';
            errorEl.textContent = '';
            try {
                const res = await fetch('/api/admin/login', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ password }) });
                const data = await res.json().catch(() => ({}));
                if (res.ok) window.location.href = '/admin';
                else { errorEl.textContent = data.error || 'Senha incorreta.'; btn.disabled = false; btn.textContent = 'Entrar'; input.select(); }
            } catch {
                errorEl.textContent = 'Erro de conexao. Tente novamente.';
                btn.disabled = false; btn.textContent = 'Entrar';
            }
        });
    </script>
</body>
</html>
